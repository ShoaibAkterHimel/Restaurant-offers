
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#111827">
  <link rel="manifest" href="manifest.webmanifest">
  <title>{{ data.project_title }}</title>
  <style>
    :root {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
      color: #172033;
      background: #f4f6f8;
      line-height: 1.45;
    }
    * { box-sizing: border-box; }
    body { margin: 0; }
    header {
      background: #111827;
      color: white;
      padding: 26px 20px;
    }
    header > div, main { max-width: 1400px; margin: auto; }
    h1 { margin: 0 0 5px; font-size: clamp(24px, 4vw, 38px); }
    h2 { margin-top: 34px; }
    .subtle { color: #6b7280; }
    header .subtle { color: #cbd5e1; }
    main { padding: 20px; }
    .notice {
      background: #fff8d8;
      border: 1px solid #ead783;
      border-radius: 12px;
      padding: 12px 14px;
      margin: 18px 0;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin: 18px 0;
    }
    .card {
      background: white;
      border: 1px solid #dfe4ea;
      border-radius: 13px;
      padding: 15px;
    }
    .number { font-size: 29px; font-weight: 800; }
    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 16px 0;
    }
    input, select {
      padding: 10px 12px;
      border: 1px solid #cbd2da;
      border-radius: 9px;
      background: white;
      font: inherit;
    }
    input { flex: 1; min-width: 230px; }
    .offer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 14px;
    }
    .offer {
      background: white;
      border: 1px solid #dfe4ea;
      border-radius: 14px;
      padding: 16px;
    }
    .offer h3 { margin: 9px 0 7px; font-size: 18px; }
    .badges { display: flex; gap: 6px; flex-wrap: wrap; }
    .badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 750;
      background: #e8edf3;
    }
    .detected { background: #dff7e8; color: #126b38; }
    .needs-review { background: #fff1c7; color: #765600; }
    .expired { background: #eceff2; color: #596575; }
    .new { background: #e6edff; color: #204ba2; }
    .social-public { background: #f0e8ff; color: #6738a5; }
    .foodpanda-area, .foodpanda-vendor { background: #ffe3f0; color: #9a2459; }
    .meta { font-size: 13px; color: #667085; margin-top: 8px; }
    a { color: #1858b7; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .table-wrap {
      overflow-x: auto;
      background: white;
      border: 1px solid #dfe4ea;
      border-radius: 13px;
    }
    table { border-collapse: collapse; width: 100%; min-width: 900px; }
    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid #edf0f3;
      text-align: left;
      vertical-align: top;
      font-size: 13px;
    }
    th { background: #fafbfc; }
    .source-ok { color: #126b38; font-weight: 700; }
    .source-bad { color: #981b1b; font-weight: 700; }
    .empty {
      padding: 26px;
      text-align: center;
      background: white;
      border: 1px solid #dfe4ea;
      border-radius: 13px;
    }
  </style>
</head>
<body>
<header>
  <div>
    <h1>{{ data.project_title }}</h1>
    <div class="subtle">{{ data.area }} · Last scan: {{ data.generated_at }}</div>
  </div>
</header>
<main>
  <div class="notice">
    “Detected” means the source currently contains a strong offer signal. Check the linked source before travelling or ordering. Social pages can be blocked or show incomplete public content.
  </div>

  <section class="cards">
    <div class="card"><div class="subtle">Detected offers</div><div class="number">{{ data.summary.offers_detected }}</div></div>
    <div class="card"><div class="subtle">New today</div><div class="number">{{ data.summary.new_today }}</div></div>
    <div class="card"><div class="subtle">Needs review</div><div class="number">{{ data.summary.needs_review }}</div></div>
    <div class="card"><div class="subtle">Sources working</div><div class="number">{{ data.summary.sources_ok }}/{{ data.summary.sources_total }}</div></div>
    <div class="card"><div class="subtle">Blocked/failed</div><div class="number">{{ data.summary.sources_blocked + data.summary.sources_failed }}</div></div>
  </section>

  <h2>Offer candidates</h2>
  <div class="controls">
    <input id="offerSearch" placeholder="Search restaurant, offer, code, condition...">
    <select id="offerStatus">
      <option value="">All statuses</option>
      <option>DETECTED</option>
      <option>NEEDS REVIEW</option>
      <option>EXPIRED</option>
    </select>
    <select id="offerSource">
      <option value="">All sources</option>
      <option value="foodpanda">Foodpanda</option>
      <option value="social">Facebook / Instagram</option>
      <option value="website">Website</option>
    </select>
  </div>

  {% if data.offers %}
  <section class="offer-grid" id="offers">
    {% for offer in data.offers %}
    <article class="offer"
      data-status="{{ offer.status }}"
      data-source="{{ offer.source_type }}"
      data-text="{{ (offer.restaurant_name ~ ' ' ~ offer.title ~ ' ' ~ offer.description ~ ' ' ~ offer.promo_code ~ ' ' ~ offer.conditions) | lower }}">
      <div class="badges">
        <span class="badge {{ offer.status | lower | replace(' ', '-') }}">{{ offer.status }}</span>
        {% if offer.is_new %}<span class="badge new">NEW</span>{% endif %}
        <span class="badge {{ offer.source_type | replace('_','-') }}">{{ offer.source_type | replace('_',' ') }}</span>
      </div>
      <h3>{{ offer.restaurant_name }}</h3>
      <strong>{{ offer.title }}</strong>
      <p>{{ offer.description }}</p>
      <div class="meta">
        {{ offer.scope }} · Confidence {{ offer.confidence }}
        {% if offer.expiry_date %} · Expires {{ offer.expiry_date }}{% endif %}
        {% if offer.promo_code %} · Code <strong>{{ offer.promo_code }}</strong>{% endif %}
      </div>
      {% if offer.conditions %}<div class="meta">Conditions: {{ offer.conditions }}</div>{% endif %}
      <div class="meta"><a href="{{ offer.source_url }}" target="_blank" rel="noopener">Verify at source</a></div>
    </article>
    {% endfor %}
  </section>
  {% else %}
  <div class="empty">No scan results yet. Run the GitHub Actions workflow once.</div>
  {% endif %}

  <h2>Source health</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Status</th><th>Source</th><th>Restaurant</th><th>Offers</th><th>Message</th><th>Link</th></tr>
      </thead>
      <tbody>
      {% for source in data.source_statuses %}
        <tr>
          <td class="{{ 'source-ok' if source.status in ['OFFER FOUND','NO OFFER FOUND'] else 'source-bad' }}">{{ source.status }}</td>
          <td>{{ source.source_type }}</td>
          <td>{{ source.restaurant_name }}</td>
          <td>{{ source.offers_found }}</td>
          <td>{{ source.message }}</td>
          <td><a href="{{ source.final_url or source.url }}" target="_blank" rel="noopener">Open</a></td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</main>
<script>
const search = document.querySelector('#offerSearch');
const status = document.querySelector('#offerStatus');
const source = document.querySelector('#offerSource');
const cards = [...document.querySelectorAll('#offers .offer')];

function filterOffers() {
  const q = (search?.value || '').toLowerCase();
  const st = status?.value || '';
  const src = source?.value || '';
  cards.forEach(card => {
    const sourceMatch =
      !src ||
      (src === 'foodpanda' && card.dataset.source.startsWith('foodpanda')) ||
      (src === 'social' && card.dataset.source === 'social_public') ||
      (src === 'website' && card.dataset.source === 'website');
    card.hidden = !(
      card.dataset.text.includes(q) &&
      (!st || card.dataset.status === st) &&
      sourceMatch
    );
  });
}
[search, status, source].forEach(el => el?.addEventListener('input', filterOffers));

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('service-worker.js').catch(() => {});
}
</script>
</body>
</html>
